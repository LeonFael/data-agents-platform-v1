# ─────────────────────────────────────────────
# Copia este archivo como .env y rellena los valores
# NUNCA subas el .env real a git
# ─────────────────────────────────────────────

# App
APP_NAME="Data Agents Platform"
DEBUG=true

# ── LLM ──────────────────────────────────────
# Proveedor activo: "claude" o "gemini"
LLM_PROVIDER=gemini

# Anthropic — obtén tu clave en console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-REEMPLAZA_CON_TU_CLAVE

# Google Gemini — obtén tu clave en aistudio.google.com/apikey
GEMINI_API_KEY=REEMPLAZA_CON_TU_CLAVE

# Archivos
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=/tmp/data_agents_uploads

# CORS — URL del frontend en desarrollo y producción
FRONTEND_URL=http://localhost:5173
